{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@bestapp/shared": ["packages/shared/src/index.ts"],
      "@bestapp/shared/*": ["packages/shared/src/*"],
      "@bestapp/ui": ["packages/ui/src/index.ts"],
      "@bestapp/ui/*": ["packages/ui/src/*"]
    }
  }
}

